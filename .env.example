# Public app origin (used to build the relay callback URL on the server).
# Example: https://english-learning.example.com  (no trailing slash)
NEXT_PUBLIC_APP_ORIGIN=

# Vercel KV / Upstash Redis (auto-injected by the Vercel KV / Upstash
# marketplace integration; for local dev, leave empty to use the in-memory
# fallback in src/lib/kv.ts).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Groq API key for server-side AI feedback (get free key at console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
