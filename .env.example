# (Optional) Public app origin override for the relay callback URL.
# If unset, the server derives the origin from the request headers — works on
# Vercel production / preview / local dev automatically. Set this only if you
# want to force a specific origin (e.g. a custom domain that differs from the
# Vercel-assigned URL). Example: https://english-learning.example.com
NEXT_PUBLIC_APP_ORIGIN=

# Vercel KV / Upstash Redis (auto-injected by the Vercel KV / Upstash
# marketplace integration; for local dev, leave empty to use the in-memory
# fallback in src/lib/kv.ts).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Groq API key for server-side AI feedback (get free key at console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
